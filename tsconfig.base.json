{
  "compilerOptions": {
    "target": "es2025",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "declaration": true,
    "composite": true,
    "sourceMap": true,
    "strict": true,
    "strictNullChecks": false,
    "preserveConstEnums": true,
    "skipLibCheck": true,
    "types": ["node"]
  }
}
