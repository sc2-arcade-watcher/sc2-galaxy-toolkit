{
	"compilerOptions": {
		"module": "commonjs",
		"target": "es2018",
		"rootDir": "src",
		"outDir": "out",
		"strictNullChecks": false,
		"lib": [
			"es2018"
		],
		"sourceMap": true,
		"allowJs": false,
		"skipLibCheck": true
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"node_modules",
		".vscode-test"
	],
	"references": [
		{ "path": "../plaxtony" }
	]
}
