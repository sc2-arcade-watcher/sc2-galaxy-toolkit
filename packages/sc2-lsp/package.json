{
    "name": "sc2-lsp",
    "version": "1.0.0",
    "description": "Unified SC2 Language Server for Galaxy Script and SC2Layout",
    "license": "MIT",
    "type": "module",
    "exports": {
        ".": {
            "types": "./lib/src/index.d.ts",
            "default": "./lib/src/index.js"
        }
    },
    "bin": {
        "sc2-lsp": "./lib/src/run.js"
    },
    "engines": { "node": ">=22.0.0" },
    "scripts": {
        "clean": "rm -rf lib/",
        "build": "tsc",
        "build:watch": "tsc --watch",
        "test": "mocha --config .mocharc.json"
    },
    "dependencies": {
        "sc2-mod": "workspace:*",
        "sc2-galaxy-lang": "workspace:*",
        "sc2-trigger": "workspace:*",
        "sc2-data": "workspace:*",
        "sc2-text": "workspace:*",
        "sc2-layout-lang": "workspace:*",
        "fast-glob": "^3.2.11",
        "sax": "^1.2.4",
        "vscode-languageserver": "^10.0.1",
        "vscode-languageserver-textdocument": "^1.0.4",
        "vscode-uri": "^3.0.0",
        "winston": "^3.2.1",
        "xml2js": "^0.4.19"
    },
    "devDependencies": {
        "@types/chai": "^4.3.0",
        "@types/mocha": "^10",
        "@types/node": "catalog:",
        "@types/sax": "^1.0.0",
        "@types/xml2js": "^0.4.2",
        "chai": "^4.3.6",
        "mocha": "^10",
        "typescript": "catalog:"
    }
}
