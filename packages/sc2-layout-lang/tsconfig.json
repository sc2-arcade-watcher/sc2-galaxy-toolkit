{
    "compilerOptions": {
        "module": "commonjs",
        "target": "es2018",
        "composite": true,
        "declaration": true,
        "outDir": "lib",
        "sourceMap": true,
        "strict": true,
        "strictNullChecks": false,
        "experimentalDecorators": true,
        "preserveConstEnums": true,
        "esModuleInterop": true,
        "lib": [
            "es2017",
            "esnext.asynciterable"
        ]
    },
    "include": [
        "src/**/*",
        "test/**/*"
    ],
    "exclude": [
        "node_modules",
        "lib"
    ],
    "references": [
        { "path": "../sc2-xml" }
    ]
}
